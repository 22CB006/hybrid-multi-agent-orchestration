{
  "info": {
    "name": "Hybrid Multi-Agent Orchestration API",
    "description": "Complete test collection for the hybrid control-plane / data-plane multi-agent orchestration system.\n\n## How to use\n1. Start the system: `redis-server && .venv/bin/python run.py`\n2. Import this collection into Postman\n3. Run requests in order within each folder, or use the Collection Runner\n\n## Flow\n- Submit a task → get a `correlation_id`\n- Poll task status using that `correlation_id`\n- The `correlation_id` is auto-saved by test scripts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "correlation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "event_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System Health",
      "description": "Endpoints to check system status, registered agents, and component health.",
      "item": [
        {
          "name": "API Root",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has API info', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('name');",
                  "    pm.expect(json).to.have.property('version');",
                  "    pm.expect(json).to.have.property('docs');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Returns API name, version, and links to docs."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"name\": \"Hybrid Multi-Agent Orchestration API\",\n  \"version\": \"0.1.0\",\n  \"description\": \"REST API for Jay's hybrid control-plane / data-plane architecture\",\n  \"docs\": \"/docs\",\n  \"health\": \"/health\"\n}"
            }
          ]
        },
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('All components are healthy', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.equal('healthy');",
                  "    pm.expect(json.components.main_agent).to.equal('healthy');",
                  "    pm.expect(json.components.redis).to.equal('healthy');",
                  "    pm.expect(json.components.message_bus).to.equal('healthy');",
                  "    pm.expect(json.components.agent_registry).to.equal('healthy');",
                  "    pm.expect(json.components.dead_letter_queue).to.equal('healthy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns overall system health and status of each component: Main Agent, Redis, Message Bus, Agent Registry, Dead Letter Queue."
          },
          "response": [
            {
              "name": "All Healthy",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"healthy\",\n  \"timestamp\": \"2026-03-08T18:50:00.000000+00:00\",\n  \"components\": {\n    \"main_agent\": \"healthy\",\n    \"redis\": \"healthy\",\n    \"message_bus\": \"healthy\",\n    \"agent_registry\": \"healthy\",\n    \"dead_letter_queue\": \"healthy\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Agent Registry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Both agents are registered', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.total_agents).to.be.at.least(2);",
                  "    var names = json.agents.map(a => a.agent_name);",
                  "    pm.expect(names).to.include('utilities');",
                  "    pm.expect(names).to.include('broadband');",
                  "});",
                  "",
                  "pm.test('Agents are healthy', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.healthy_agents).to.equal(json.total_agents);",
                  "    pm.expect(json.unhealthy_agents).to.equal(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/agents",
              "host": ["{{base_url}}"],
              "path": ["agents"]
            },
            "description": "Returns all registered data plane agents with their health status, active tasks, uptime, and heartbeat info."
          },
          "response": [
            {
              "name": "Both Agents Registered",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"agents\": [\n    {\n      \"agent_name\": \"utilities\",\n      \"status\": \"healthy\",\n      \"last_heartbeat\": \"2026-03-08T18:51:00.000000+00:00\",\n      \"active_tasks\": 0,\n      \"uptime_seconds\": 120,\n      \"consecutive_missed_heartbeats\": 0\n    },\n    {\n      \"agent_name\": \"broadband\",\n      \"status\": \"healthy\",\n      \"last_heartbeat\": \"2026-03-08T18:51:00.000000+00:00\",\n      \"active_tasks\": 0,\n      \"uptime_seconds\": 120,\n      \"consecutive_missed_heartbeats\": 0\n    }\n  ],\n  \"total_agents\": 2,\n  \"healthy_agents\": 2,\n  \"unhealthy_agents\": 0\n}"
            }
          ]
        }
      ]
    },
