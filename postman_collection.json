                  "    if (json.events && json.events.length > 0) {",
                  "        pm.collectionVariables.set('event_id', json.events[0].event_id);",
                  "        console.log('Saved event_id: ' + json.events[0].event_id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
