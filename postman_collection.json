    {
      "name": "Dead Letter Queue",
      "description": "Inspect and retry failed events.\n\nThe DLQ will be empty unless a task has failed after all retry attempts (3 retries with exponential backoff).",
      "item": [
        {
          "name": "Get Dead Letter Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has events array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('events');",
                  "    pm.expect(json).to.have.property('total_events');",
                  "    pm.expect(json.events).to.be.an('array');",
                  "});",
                  "",
                  "// Auto-save first event_id if available",
